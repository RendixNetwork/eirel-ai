  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["eirel", "submissions", "deployments"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "EIREL — Submissions & Deployments",
  "uid": "eirel-submissions-deployments",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Total submissions",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "eirel_owner_submissions_total"}],
      "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active deployments",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "eirel_owner_active_deployments_total"}],
      "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Unhealthy deployments",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "eirel_owner_unhealthy_deployments_total"}],
      "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Serving deployments",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "eirel_owner_serving_deployments_total"}],
      "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Serving releases",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "eirel_owner_serving_releases_total"}],
      "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Current serving fleet",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "eirel_owner_current_serving_fleet_total"}],
      "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 200,
      "type": "row",
      "title": "Submission lifecycle",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "panels": []
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Submissions by status (stacked)",
      "gridPos": {"h": 8, "w": 14, "x": 0, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (status) (eirel_owner_submissions)", "legendFormat": "{{status}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "none", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 30, "stacking": {"mode": "normal"}}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 8,
      "type": "table",
      "title": "Submissions by family and status",
      "gridPos": {"h": 8, "w": 10, "x": 14, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (family, status) (eirel_owner_submissions)", "instant": true, "format": "table"}
      ],
      "fieldConfig": {"defaults": {"custom": {"align": "left"}}, "overrides": []},
      "options": {"showHeader": true}
    },
    {
      "id": 300,
      "type": "row",
      "title": "Deployment health by family",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "panels": []
    },
    {
      "id": 9,
      "type": "barchart",
      "title": "Deployments by family and status",
      "gridPos": {"h": 8, "w": 14, "x": 0, "y": 15},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (family, status) (eirel_owner_deployments)", "instant": true, "format": "table", "legendFormat": "{{family}} / {{status}}"}
      ],
      "fieldConfig": {"defaults": {"custom": {"axisLabel": "", "axisPlacement": "auto"}}, "overrides": []},
      "options": {"orientation": "auto", "xTickLabelRotation": 0, "stacking": "normal", "legend": {"displayMode": "table", "placement": "right"}}
    },
    {
      "id": 10,
      "type": "table",
      "title": "Deployments (family / status / health)",
      "gridPos": {"h": 8, "w": 10, "x": 14, "y": 15},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (family, status, health) (eirel_owner_deployments)", "instant": true, "format": "table"}
      ],
      "fieldConfig": {"defaults": {"custom": {"align": "left"}}, "overrides": []},
      "options": {"showHeader": true}
    },
    {
      "id": 400,
      "type": "row",
      "title": "Fleet utilization",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "panels": []
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Fleet CPU utilization",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum(eirel_owner_runtime_reserved_cpu_millis) / sum(eirel_owner_node_cpu_millis)"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.8}, {"color": "red", "value": 0.95}]},
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Verified runtime nodes",
      "gridPos": {"h": 6, "w": 8, "x": 6, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "eirel_owner_runtime_verified_nodes", "legendFormat": "verified"}],
      "fieldConfig": {"defaults": {"unit": "none", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    },
    {
      "id": 13,
      "type": "table",
      "title": "Per-node deployment allocation",
      "gridPos": {"h": 6, "w": 10, "x": 14, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "eirel_owner_node_deployments", "instant": true, "format": "table"}
      ],
      "fieldConfig": {"defaults": {"custom": {"align": "left"}}, "overrides": []},
      "options": {"showHeader": true}
    },
    {
      "id": 500,
      "type": "row",
      "title": "Submission → pod → node",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 30},
      "panels": []
    },
    {
      "id": 14,
      "type": "table",
      "title": "Active deployments: hotkey → deployment → pod → node",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 31},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "(eirel_owner_deployment_info * on(deployment_id) group_left(pod) label_replace(kube_pod_labels{namespace=\"eirel-miners\"}, \"deployment_id\", \"$1\", \"label_eirel_dev_submission_id\", \"(.*)\")) * on(pod) group_left(phase) (kube_pod_status_phase{namespace=\"eirel-miners\"} == 1)",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "Value": true,
              "instance": true,
              "job": true,
              "is_active": true,
              "submission_id": true
            },
            "indexByName": {
              "hotkey": 0,
              "family": 1,
              "deployment_id": 2,
              "pod": 3,
              "node": 4,
              "status": 5,
              "health": 6,
              "phase": 7
            },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {"custom": {"align": "left"}},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "health"},
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "healthy": {"color": "green", "index": 0},
                      "unhealthy": {"color": "red", "index": 1},
                      "unknown": {"color": "orange", "index": 2}
                    }
                  }
                ]
              },
              {"id": "custom.cellOptions", "value": {"type": "color-background"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "phase"},
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "Running": {"color": "green", "index": 0},
                      "Pending": {"color": "orange", "index": 1},
                      "Failed": {"color": "red", "index": 2}
                    }
                  }
                ]
              },
              {"id": "custom.cellOptions", "value": {"type": "color-background"}}
            ]
          }
        ]
      },
      "options": {"showHeader": true}
    }
  ]
}

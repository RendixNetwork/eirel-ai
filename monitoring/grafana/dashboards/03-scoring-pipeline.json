{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["eirel", "scoring", "validator"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "EIREL — Scoring Pipeline",
  "uid": "eirel-scoring-pipeline",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Epoch snapshots",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "panels": []
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Open / pending snapshots",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "eirel_owner_open_run_snapshots", "legendFormat": "open run"},
        {"refId": "B", "expr": "eirel_owner_pending_aggregate_snapshots", "legendFormat": "pending aggregate"}
      ],
      "fieldConfig": {"defaults": {"unit": "none", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 15}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Validator score submissions (rate)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "rate(eirel_owner_validator_score_submissions_total[5m])", "legendFormat": "submissions/s"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 15}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    },
    {
      "id": 200,
      "type": "row",
      "title": "Benchmark runs",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "panels": []
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Benchmark starts by family (rate)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (family) (rate(eirel_validator_benchmark_runs_started_total[5m]))", "legendFormat": "{{family}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 4,
      "type": "heatmap",
      "title": "Benchmark run duration",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (le) (rate(eirel_validator_benchmark_run_duration_seconds_bucket[15m]))", "format": "heatmap", "legendFormat": "{{le}}"}
      ],
      "fieldConfig": {"defaults": {"custom": {"hideFrom": {"legend": false, "tooltip": false, "viz": false}}, "unit": "s"}, "overrides": []},
      "options": {"calculate": false, "yAxis": {"unit": "s"}, "color": {"mode": "scheme", "scheme": "Oranges", "steps": 64, "exponent": 0.5}, "legend": {"show": true}, "tooltip": {"show": true}}
    },
    {
      "id": 5,
      "type": "table",
      "title": "Completed benchmark outcomes by family",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (family, outcome) (increase(eirel_validator_benchmark_runs_completed_total[1h]))", "instant": true, "format": "table"}
      ],
      "fieldConfig": {"defaults": {"custom": {"align": "left"}}, "overrides": []},
      "options": {"showHeader": true}
    },
    {
      "id": 300,
      "type": "row",
      "title": "Judges",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 26},
      "panels": []
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Judge invocation rate by model",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 27},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (judge_model) (rate(eirel_validator_judge_invocations_total[5m]))", "legendFormat": "{{judge_model}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Judge disagreement rate by family",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 27},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (family) (rate(eirel_validator_judge_disagreements_total[15m]))", "legendFormat": "{{family}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Judge p95 latency by family",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 27},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.95, sum by (le, family) (rate(eirel_validator_judge_duration_seconds_bucket[15m])))", "legendFormat": "{{family}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 400,
      "type": "row",
      "title": "Weight setter",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 35},
      "panels": []
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Submission rate by mode/status (stacked)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 36},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (mode, status) (rate(eirel_weight_setter_submissions_total[5m]))", "legendFormat": "{{mode}} / {{status}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 30, "stacking": {"mode": "normal"}}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "p95 submission duration by family/mode",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 36},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.95, sum by (le, family, mode) (rate(eirel_weight_setter_submission_duration_seconds_bucket[15m])))", "legendFormat": "{{family}} / {{mode}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Age of last successful submission (max family)",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 44},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "time() - max(eirel_weight_setter_last_success_timestamp_seconds)"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1800}, {"color": "red", "value": 3600}]},
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "auto"}
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Chain error rate",
      "gridPos": {"h": 6, "w": 16, "x": 8, "y": 44},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (error_type) (rate(eirel_weight_setter_chain_errors_total[5m]))", "legendFormat": "{{error_type}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 200,
      "type": "row",
      "title": "Validator economics (per-run cost)",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 50},
      "panels": []
    },
    {
      "id": 201,
      "type": "barchart",
      "title": "Validator-paid spend by run (oracle + judge)",
      "description": "Per-validator stacked bar of validator-paid spend per run. Two segments per validator: oracle (3-oracle layer + Chutes reconciler) and judge (eiretes pairwise/multi/eval). Source: eirel_owner_validator_run_oracle_cost_usd + eirel_owner_validator_run_judge_cost_usd.",
      "gridPos": {"h": 9, "w": 16, "x": 0, "y": 51},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "eirel_owner_validator_run_oracle_cost_usd", "legendFormat": "{{hotkey}} oracle (run {{run_id}})", "instant": true},
        {"refId": "B", "expr": "eirel_owner_validator_run_judge_cost_usd", "legendFormat": "{{hotkey}} judge (run {{run_id}})", "instant": true}
      ],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4, "custom": {"lineWidth": 1, "fillOpacity": 80}}, "overrides": []},
      "options": {"orientation": "horizontal", "stacking": "normal", "legend": {"displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 202,
      "type": "stat",
      "title": "Total validator-paid spend (latest run)",
      "description": "Sum across all validators of oracle+judge spend in the most recent run scraped.",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 51},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum(eirel_owner_validator_run_total_cost_usd * on(run_id) group_left() topk(1, max by (run_id) (eirel_owner_validator_run_total_cost_usd)))"}
      ],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 25}, {"color": "red", "value": 100}]}, "color": {"mode": "thresholds"}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 203,
      "type": "stat",
      "title": "Avg cost per claimed task (fleet, latest run)",
      "description": "fleet total / fleet tasks_claimed in the most recent run.",
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 55},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum(eirel_owner_validator_run_total_cost_usd * on(run_id) group_left() topk(1, max by (run_id) (eirel_owner_validator_run_total_cost_usd))) / clamp_min(sum(eirel_owner_validator_run_tasks_claimed * on(run_id) group_left() topk(1, max by (run_id) (eirel_owner_validator_run_total_cost_usd))), 1)"}
      ],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 204,
      "type": "timeseries",
      "title": "Per-validator total cost trend (latest open run)",
      "description": "Validator-paid spend over time per hotkey. The owner-api scrapes the DB roll-up at 5s; steps reflect new task-evaluation submissions.",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 60},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "eirel_owner_validator_run_total_cost_usd * on(run_id) group_left() topk(1, max by (run_id) (eirel_owner_validator_run_total_cost_usd))", "legendFormat": "{{hotkey}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4, "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 15}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}}
    }
  ]
}

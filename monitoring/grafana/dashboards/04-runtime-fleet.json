{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["eirel", "runtime", "nodes"],
  "templating": {
    "list": [
      {
        "name": "node",
        "label": "Node",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": {"qryType": 1, "query": "label_values(eirel_owner_node_ready, node)", "refId": "StandardVariableQuery"},
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "sort": 1,
        "current": {"selected": false, "text": "All", "value": "$__all"}
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "EIREL — Runtime Fleet",
  "uid": "eirel-runtime-fleet",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Inventory",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Node count",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "eirel_owner_node_count"}],
      "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Ready nodes",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "sum(eirel_owner_node_ready)"}],
      "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Schedulable nodes",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "sum(eirel_owner_node_schedulable)"}],
      "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total pod capacity",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "sum(eirel_owner_node_pod_capacity)"}],
      "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 200,
      "type": "row",
      "title": "CPU per node",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "panels": []
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU utilization by node",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "100 - (avg by (node) (rate(node_cpu_seconds_total{job=\"runtime_node\",mode=\"idle\",node=~\"$node\"}[5m])) * 100)", "legendFormat": "{{node}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "min": 0, "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 300,
      "type": "row",
      "title": "Memory per node",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "panels": []
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Memory utilization by node",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 15},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "(1 - node_memory_MemAvailable_bytes{job=\"runtime_node\",node=~\"$node\"} / node_memory_MemTotal_bytes{job=\"runtime_node\",node=~\"$node\"}) * 100", "legendFormat": "{{node}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "min": 0, "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 400,
      "type": "row",
      "title": "Disk",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "panels": []
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Available disk (owner-api inventory)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "eirel_owner_node_disk_avail_bytes{node=~\"$node\"}", "legendFormat": "{{node}}", "instant": true}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 1073741824}, {"color": "green", "value": 5368709120}]},
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "options": {"orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Filesystem available (node_exporter)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "node_filesystem_avail_bytes{job=\"runtime_node\", mountpoint=\"/\", node=~\"$node\"}", "legendFormat": "{{node}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "decbytes", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 500,
      "type": "row",
      "title": "Network & disk IO",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32},
      "panels": []
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Network RX",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 33},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (node) (rate(node_network_receive_bytes_total{job=\"runtime_node\",node=~\"$node\"}[5m]))", "legendFormat": "{{node}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "binBps", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Network TX",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 33},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (node) (rate(node_network_transmit_bytes_total{job=\"runtime_node\",node=~\"$node\"}[5m]))", "legendFormat": "{{node}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "binBps", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Disk read",
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 33},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (node) (rate(node_disk_read_bytes_total{job=\"runtime_node\",node=~\"$node\"}[5m]))", "legendFormat": "{{node}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "binBps", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Disk write",
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 33},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (node) (rate(node_disk_written_bytes_total{job=\"runtime_node\",node=~\"$node\"}[5m]))", "legendFormat": "{{node}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "binBps", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 600,
      "type": "row",
      "title": "Capacity pressure",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 39},
      "panels": []
    },
    {
      "id": 13,
      "type": "bargauge",
      "title": "CPU reserved / total per node",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "(sum by (node) (eirel_owner_node_reserved_cpu_millis{node=~\"$node\"})) / (sum by (node) (eirel_owner_node_cpu_millis{node=~\"$node\"}))", "legendFormat": "{{node}}", "instant": true}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.8}, {"color": "red", "value": 0.95}]},
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "options": {"orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 14,
      "type": "bargauge",
      "title": "Memory reserved / total per node",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "(sum by (node) (eirel_owner_node_reserved_memory_bytes{node=~\"$node\"})) / (sum by (node) (eirel_owner_node_memory_bytes{node=~\"$node\"}))", "legendFormat": "{{node}}", "instant": true}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.8}, {"color": "red", "value": 0.95}]},
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "options": {"orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": {"calcs": ["lastNotNull"]}}
    }
  ]
}

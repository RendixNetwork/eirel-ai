# Copy this file to configmap.env and fill in the values.
# configmap.env is consumed by kustomize configMapGenerator(behavior: merge)
# and its keys OVERRIDE / EXTEND ../../base/configmap.yaml and the static
# values from configmap-patch.yaml.
# Do NOT commit configmap.env — it is gitignored.

# -- Bittensor / metagraph ----------------------------------------------------
BITTENSOR_NETWORK=finney
BITTENSOR_NETUID=

# -- Owner identity -----------------------------------------------------------
EIREL_OWNER_WALLET_NAME=
EIREL_OWNER_HOTKEY_NAME=

# -- Miner runtime image ------------------------------------------------------
# For production, pin to a specific tag from your private registry.
EIREL_OWNER_RUNTIME_IMAGE=rendixnetwork/eirel-miner-runtime:latest

# -- Eiretes judge ------------------------------------------------------------
EIREL_JUDGE_SERVICE_URL=http://eiretes-judge.eirel-prod.svc.cluster.local:8095

# -- Launch mode --------------------------------------------------------------
LAUNCH_MODE=launch

# -- CORS (production should pin to your actual origin(s)) --------------------
EIREL_CORS_ALLOW_ORIGINS=https://leaderboard.eirel.example.com

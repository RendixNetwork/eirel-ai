# Copy to secret.env before applying the production overlay (gitignored).
# Assumes EXTERNAL managed Postgres, Redis, and S3-compatible object storage.

# -- External database + cache ------------------------------------------------
DATABASE_URL=postgresql+psycopg://eirel:replace-me@managed-postgres.example.com:5432/eirel
REDIS_URL=redis://managed-redis.example.com:6379/0

# -- API keys / internal tokens -----------------------------------------------
GATEWAY_API_KEYS=replace-me-gateway-key
API_GATEWAY_API_KEY=replace-me-gateway-key
CONSUMER_API_KEYS=replace-me-consumer-key
EIREL_INTERNAL_SERVICE_TOKEN=replace-me-internal-token
EIREL_PROVIDER_PROXY_MASTER_TOKEN=replace-me-provider-token

# -- Provider / judge LLM keys ------------------------------------------------
EIREL_PROVIDER_OPENAI_API_KEY=
EIREL_PROVIDER_ANTHROPIC_API_KEY=
EIREL_PROVIDER_OPENROUTER_API_KEY=
EIREL_PROVIDER_CHUTES_API_KEY=
EIREL_JUDGE_API_KEY=

# -- External S3-compatible object storage ------------------------------------
OBJECT_STORAGE_ACCESS_KEY_ID=replace-me-object-storage-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-me-object-storage-secret
OBJECT_STORAGE_ENDPOINT_URL=https://s3.example.com
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_PREFIX=production

# -- Bittensor mnemonics (hot secrets) ----------------------------------------
# Names match what the code reads:
#   validation/validator/engine.py:79  → EIREL_VALIDATOR_MNEMONIC
# NEVER commit real mnemonics.
EIREL_MINER_MNEMONIC=
EIREL_VALIDATOR_MNEMONIC=

# Copy this file to configmap.env and fill in the values.
# configmap.env is consumed by kustomize configMapGenerator(behavior: merge)
# and its keys OVERRIDE / EXTEND the defaults in ../../base/configmap.yaml.
# Do NOT commit configmap.env — it is gitignored.

# -- Bittensor / metagraph ----------------------------------------------------
BITTENSOR_NETWORK=finney
BITTENSOR_NETUID=36

# -- Owner identity -----------------------------------------------------------
# Bittensor wallet/hotkey mounted on the pod at
# ~/.bittensor/wallets/<NAME>/hotkeys/<HOTKEY>. The owner-api loads this at
# startup to derive owner_hotkey_ss58 used to verify admin-signed requests.
EIREL_OWNER_WALLET_NAME=
EIREL_OWNER_HOTKEY_NAME=

# -- Miner runtime image ------------------------------------------------------
# Image owner-api runs for each managed miner pod. Replace with your registry.
EIREL_OWNER_RUNTIME_IMAGE=rendixnetwork/miner-runtime:v1

# -- Eiretes judge ------------------------------------------------------------
# For Mode B, the judge is typically an external Chutes endpoint. Override
# EIREL_JUDGE_SERVICE_URL to point at an in-cluster eiretes-judge Deployment
# if you deploy one as part of the overlay.
EIREL_JUDGE_SERVICE_URL=http://eiretes-judge.eirel.svc.cluster.local:8095
EIREL_JUDGE_MODEL=moonshotai/Kimi-K2.5-TEE
EIREL_JUDGE_BASE_URL=https://llm.chutes.ai/v1
EIREL_JUDGE_API_BASE_URL=https://llm.chutes.ai/v1
EIREL_JUDGE_TIMEOUT_SECONDS=60
EIREL_ENSEMBLE_JUDGE_MODEL=zai-org/GLM-5.1-TEE
EIREL_ENSEMBLE_JUDGE_BASE_URL=https://llm.chutes.ai/v1
EIREL_ENSEMBLE_JUDGE_DISAGREEMENT_THRESHOLD=0.20

# -- Launch mode --------------------------------------------------------------
# development | launch
LAUNCH_MODE=development

# -- CORS (for the public /api/v1/dashboard/* endpoints) ----------------------
# Comma-separated origins. Leave blank or "*" to allow any (dev only).
EIREL_CORS_ALLOW_ORIGINS=*

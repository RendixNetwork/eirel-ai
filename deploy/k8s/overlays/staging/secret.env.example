# Copy to secret.env before applying the staging overlay (gitignored).
# Every key here ends up in Secret/eirel-control-plane-secrets via
# kustomize secretGenerator.

# -- Database + Redis (in-cluster, from dependencies.yaml) --------------------
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgresql+psycopg://eirel:replace-me@postgres.eirel.svc.cluster.local:5432/eirel

# -- API keys / internal tokens -----------------------------------------------
GATEWAY_API_KEYS=staging-gateway-key
API_GATEWAY_API_KEY=staging-gateway-key
CONSUMER_API_KEYS=staging-consumer-key
EIREL_INTERNAL_SERVICE_TOKEN=replace-me-internal-token
EIREL_PROVIDER_PROXY_MASTER_TOKEN=replace-me-provider-token
EIREL_PROVIDER_PROXY_ALLOW_MOCK=false

# -- Provider / judge LLM keys ------------------------------------------------
EIREL_PROVIDER_OPENAI_API_KEY=
EIREL_PROVIDER_ANTHROPIC_API_KEY=
EIREL_PROVIDER_OPENROUTER_API_KEY=
EIREL_PROVIDER_CHUTES_API_KEY=
# Eiretes judge API key. Required if owner-api/validator call an external
# Chutes-hosted judge. Code reads EIREL_JUDGE_API_KEY.
EIREL_JUDGE_API_KEY=
EIREL_ENSEMBLE_JUDGE_API_KEY=

# -- Dataset paths (stable across envs; kept in secrets to avoid baking into a
#    public ConfigMap if they contain anything non-public) -------------------
EIREL_OWNER_DATASET_ROOT_PATH=/app/eirel-ai/data/owner_datasets/families
EIREL_CALIBRATION_FIXTURES_ROOT_PATH=/app/eirel-ai/data/calibration
EIREL_WORKFLOW_CORPUS_ROOT_PATH=/app/eirel-ai/data/workflow_corpus
EIREL_RESEARCH_TOOL_CATALOG_PATH=/app/eirel-ai/data/research_tool_catalog.json
EIREL_RETRIEVAL_SNAPSHOT_PATH=/app/eirel-ai/data/retrieval_snapshots/default_v1/snapshot.json

# -- Bittensor mnemonics (hot secrets) ----------------------------------------
# Names match what the code reads:
#   validation/validator/engine.py:79  → EIREL_VALIDATOR_MNEMONIC
# NEVER commit real mnemonics.
EIREL_MINER_MNEMONIC=
EIREL_VALIDATOR_MNEMONIC=

# Copy this file to configmap.env and fill in the values.
# configmap.env is consumed by kustomize configMapGenerator (behavior: merge)
# and its keys OVERRIDE / EXTEND the static defaults in configmap.yaml.
# Do NOT commit configmap.env — it is gitignored.
#
# Every key below is deployment-specific (chain, wallets, images, endpoints).
# The keys in configmap.yaml are deployment-agnostic defaults you usually
# don't need to touch.

# -- Bittensor / metagraph ----------------------------------------------------
# Network: "test" for testnet, "finney" for mainnet, "local" for local subtensor.
BITTENSOR_NETWORK=finney
BITTENSOR_NETUID=36

# -- Owner identity -----------------------------------------------------------
# The Bittensor wallet/hotkey the owner-api loads to sign admin responses.
# Expected on the k3s node at ~/.bittensor/wallets/<NAME>/hotkeys/<HOTKEY>.
EIREL_OWNER_WALLET_NAME=
EIREL_OWNER_HOTKEY_NAME=

# -- Miner runtime image ------------------------------------------------------
# The image owner-api runs for each managed miner pod. This must be resolvable
# from within the k3s cluster — typically the in-cluster registry, e.g.
# <NODE_IP>:30500/miner-runtime:v1 — so nodes can pull without external auth.
EIREL_OWNER_RUNTIME_IMAGE=rendixnetwork/miner-runtime:v1

# -- Eiretes judge ------------------------------------------------------------
# URL owner-api calls to submit judge requests. For hybrid mode, point at the
# compose-hosted eiretes-judge container on the node host IP:18095.
EIREL_JUDGE_SERVICE_URL=http://127.0.0.1:18095
EIREL_JUDGE_MODEL=moonshotai/Kimi-K2.5-TEE
EIREL_JUDGE_BASE_URL=https://llm.chutes.ai/v1
EIREL_JUDGE_TIMEOUT_SECONDS=60

# -- Ensemble judge (optional disagreement check) -----------------------------
# Leave blank to disable the ensemble check.
EIREL_ENSEMBLE_JUDGE_MODEL=zai-org/GLM-5.1-TEE
EIREL_ENSEMBLE_JUDGE_BASE_URL=https://llm.chutes.ai/v1
EIREL_ENSEMBLE_JUDGE_DISAGREEMENT_THRESHOLD=0.20

# -- Run cadence --------------------------------------------------------------
# ISO-8601 UTC timestamp for when Run 1 opens. Leave blank to start immediately
# at owner-api boot. Set to ~15 minutes after deploy to allow miner submissions
# before the first run locks in.
EIREL_FIRST_RUN_START_TIME=
EIREL_RUN_DURATION_DAYS=1
EIREL_RUN_BUDGET_USD=30.0

# -- Submission fee / treasury -----------------------------------------------
# Fee in TAO charged per miner submission; treasury is the SS58 that receives
# the payment. Set fee to 0 only for testnet/dev.
EIREL_SUBMISSION_FEE_TAO=0.1
EIREL_SUBMISSION_TREASURY_ADDRESS=

# -- Public / external URLs ---------------------------------------------------
# Used by browsers + external validators. For NodePort exposure, this is
# http://<node-public-ip>:30020.
OWNER_API_PUBLIC_URL=

# CORS allowlist (comma-separated). Empty / "*" = allow any origin (dev only).
EIREL_CORS_ALLOW_ORIGINS=
